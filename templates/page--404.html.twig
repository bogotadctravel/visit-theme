{#
/**
 * @file
 * Plantilla personalizada para el error 404.
 * Colores: Amarillo (#fac533), Azul (#314059)
 */
#}

<style>
  .error-404-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    color: #314059;
    background-color: #ffffff;
    padding: 20px;
  }

  .error-404-content {
    text-align: center;
    max-width: 600px;
  }

  .error-code {
    font-size: 120px;
    font-weight: 900;
    margin: 0;
    color: #fac533;
    line-height: 1;
  }

  .error-title {
    font-size: 2rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    color: #314059;
  }

  .error-description {
    font-size: 1.1rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .btn-home {
    display: inline-block;
    padding: 12px 30px;
    background-color: #314059;
    color: #fac533 !important;
    text-decoration: none;
    font-weight: bold;
    border-radius: 5px;
    transition: background-color 0.3s ease;
  }

  .btn-home:hover {
    background-color: #fac533;
    color: #314059 !important;
  }

  .site-indicator {
    margin-top: 30px;
    font-size: 0.9rem;
    border-top: 2px solid #fac533;
    padding-top: 15px;
    display: inline-block;
  }
</style>

<div class="error-404-container">
  <div class="error-404-content">
    <h1 class="error-code">404</h1>
    
    {# Lógica para diferenciar contenido según el dominio o nombre del sitio #}
    {% set site_name = current_site_name|default(site_name) %}
    
    <h2 class="error-title">¡Ups! Página no encontrada</h2>
    
    <p class="error-description">
      Lo sentimos, la página que estás buscando no existe o ha sido movida. 
      Asegúrate de que la URL sea correcta o regresa al inicio.
    </p>

    <a href="{{ front_page }}" class="btn-home">VOLVER AL INICIO</a>

  </div>
</div>