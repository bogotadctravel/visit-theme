    <main>
        <section class="places" id="places">
            <div class="places__header">
                <h1>{{"ui.ideal_place_intro"|trans}}</h1>
            </div>
            <div class="places__search-card">
                <label class="places__search-field">
                    <span class="places__search-label">{{"ui.service_type"|trans}}</span>
                    <div class="places-input places-input--select">
                        <span class="places-input__icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                                <circle cx="11" cy="11" r="6" />
                                <path d="m16.5 16.5 3.5 3.5" stroke-linecap="round" />
                            </svg>
                        </span>
                        <select name="type" aria-label="Tipo de servicio">
                            {% for item in taxonomy("tipos_de_proveedor_mice") %}
                            <option value="{{item.tid}}" >{{ item.name }}</option>
                            {% endfor %}
                        </select>
                        <span class="places-input__icon places-input__icon--trailing" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                                <path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    </div>
                </label>
            </div>

            <div class="places__grid" aria-live="polite">
            {% for item in proveedores_conecta %}
                <a class="place-card" style="position: relative;" href="{{item.url}}" data-type="{{ item.fields.field_criterios_de_busqueda_prov.0.target_id  }}">
                    <div class="place-card__media place-card__media--a" aria-hidden="true" style="background-image: url({{item.image}});"></div>
                    <div class="place-card__body">
                        <h3 class="place-card__title">{{ item.title }}</h3>
                    </div>
                      {% if item.field_aprobado_marca_ciudad == '1' %}
                    <div class="marca" style="position: absolute;top: 130px;right: 0;width: 160px;height: 50px;">
                    <img src="/{{ directory }}/images/marcaciudad.png" alt="Marca de la ciudad"  width="100%"/>
                    </div>
                    {% endif %}
                </a>
            {% endfor %}
            </div>
        </section>
    </main>