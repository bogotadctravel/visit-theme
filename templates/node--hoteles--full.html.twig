<div class="atractivo hotel-profile">
    <main>
        {% set banner_image = null %}
        {% if node.field_mainimg.entity %}
            {% set banner_image = file_url(node.field_mainimg.entity.fileuri) %}
        {% endif %}

        {% if banner_image %}
        <div class="banner" style="background-image: url('{{ banner_image }}');">
            <div class="container">
                <div class="text">
                    {# Tipo de Alojamiento (Ej: Hotel Boutique, Hostal, Resort) #}
                    {% if node.field_tipo_de_alojamiento|length > 0 %}
                        <div class="badge-alojamiento">
                            {{ node.field_tipo_de_alojamiento.0.entity.name.value }}
                        </div>
                    {% endif %}

                    <h1>{{ node.getTitle() }}</h1>
                    
                    <div class="comollegar">
                        {% if node.field_direccion.0.value is not empty %}
                            <p>📍 {{ node.field_direccion.0.value }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <div class="flex">
            <div class="main-content">
                
                {% if node.field_picgallery|length > 0 %}
                    <div class="galeria-grid">
                        {% for item in node.field_picgallery|slice(0,5) %}
                            <a href="{{ file_url(item.entity.fileuri) }}" data-fancybox="gallery" data-caption="{{ item.title }}">
                                <img src="{{ file_url(item.entity.fileuri) }}" alt="{{ item.alt }}">
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if content.body is not empty %}
                    <div class="desc">
                        {{ content.body }}
                    </div>
                {% endif %}

                {% if node.field_servicios_del_hotel|length > 0 %}
                    <div class="hotel-amenities" style="margin: 40px 0; border-top: 1px solid #e2e8f0; padding-top: 30px;">
                        <h3 style="font-size: 24px; font-weight: 800; color: #1e293b; margin-bottom: 20px;">
                            ¿Qué ofrece este lugar?
                        </h3>
                        <ul class="amenities-grid">
                            {% for item in node.field_servicios_del_hotel %}
                                <li>
                                    {# Intentamos cargar el ícono, si no existe ponemos un check genérico #}
                                    {% if item.entity.field_icono.entity.fileuri %}
                                        <img src="{{ file_url(item.entity.field_icono.entity.fileuri) }}" alt="{{ item.entity.name.value }}">
                                    {% else %}
                                        <span class="default-icon">✔️</span>
                                    {% endif %}
                                    <span>{{ item.entity.name.value }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}

                <div class="flexmap" style="margin-top: 40px; border-top: 1px solid #e2e8f0; padding-top: 30px;">
                    <h3 style="font-size: 24px; font-weight: 800; color: #1e293b; margin-bottom: 20px;">
                        ¿Dónde estarás?
                    </h3>
                    
                    {% if node.field_latlong.0.value is not empty %}
                        <div class="map" rel="noopener">
                            <iframe id="mapNode" width="100%" height="400" style="border:0; border-radius: 16px;" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" src="https://www.google.com/maps?q={{node.field_latlong.0.value}},{{node.field_latlong.1.value}}&z=15&output=embed"></iframe>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="sidebar-reserva">
                <div class="booking-card">
                    
                    {# Rango de Precios Destacado #}
                    {% if node.field_rango_de_precios_del_hotel|length > 0 %}
                        <div class="price-range">
                            <span class="label">Rango de precios:</span>
                            <span class="value">{{ node.field_rango_de_precios_del_hotel.0.entity.name.value }}</span>
                        </div>
                    {% endif %}

                    <h3>Planea tu estadía</h3>

                    {# Tipos de Habitación #}
                    {% if node.field_tipos_de_habitacion_dispon|length > 0 %}
                        <div class="room-types" style="margin-bottom: 25px;">
                            <strong style="display: block; font-size: 13px; color: #64748b; text-transform: uppercase; margin-bottom: 10px;">
                                Habitaciones disponibles:
                            </strong>
                            <ul style="list-style: none; padding: 0; margin: 0;">
                                {% for item in node.field_tipos_de_habitacion_dispon %}
                                    <li style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px; font-weight: 500; color: #334155;">
                                        🛏️ {{ item.entity.name.value }}
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <div class="tags-group">
                        {# Recomendado para #}
                        {% if node.field_turpara|length > 0 %}
                            <div class="tag-block">
                                <strong>Ideal para:</strong>
                                <div class="tag-container">
                                    {% for item in node.field_turpara %}
                                        <span class="tag-item">{{ item.entity.name.value }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        {# Ubicación (Zonas y Localidades) #}
                        {% if node.field_turzone|length > 0 or node.field_turdistr|length > 0 %}
                            <div class="tag-block">
                                <strong>Ubicación:</strong>
                                <div class="tag-container">
                                    {% for item in node.field_turzone %}<span class="tag-item geo">{{ item.entity.name.value }}</span>{% endfor %}
                                    {% for item in node.field_turdistr %}<span class="tag-item geo">{{ item.entity.name.value }}</span>{% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>

                    {# Contacto del Hotel #}
                    {% if node.field_telefono.0.value is not empty or node.field_correo.0.value is not empty %}
                        <div class="contact-card" style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #f1f5f9;">
                            <strong style="display:block; margin-bottom:10px; font-size:13px; color:#64748b; text-transform:uppercase;">Contacto directo:</strong>
                            {% if node.field_telefono.0.value is not empty %}
                                <a href="tel:{{node.field_telefono.0.value}}" class="contact-link">📞 {{node.field_telefono.0.value}}</a><br>
                            {% endif %}
                            {% if node.field_correo.0.value is not empty %}
                                <a href="mailto:{{node.field_correo.0.value}}" class="contact-link">✉️ {{node.field_correo.0.value}}</a>
                            {% endif %}
                        </div>
                    {% endif %}

                    {# Botones de Acción (Reserva y Web) #}
                    <div class="action-buttons" style="margin-top: 25px;">
                        {% if node.field_linkreservas.0.url is not empty %}
                            <a href="{{node.field_linkreservas.0.url}}" target="_blank" class="reservaLink">
                                Consultar disponibilidad
                            </a>
                        {% endif %}
                        
                        {% if node.field_weblink.0.url is not empty %}
                            <a href="{{node.field_weblink.0.url}}" target="_blank" class="reservaLink secondary-btn" style="margin-top: 10px;">
                                Visitar sitio web
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {% if nodos_cercanos|length > 0 %}
        <div class="lugares">
            <h4>{{"ui.places_nearby"|t({'@place': node.getTitle()})}}</h4>
            <ul>
                {% for item in nodos_cercanos|shuffle|slice(0, 4) %}
                <li>
                    <a href="{{ path('entity.node.canonical', {'node': item.id}) }}">
                        <div class="image"><img src="{{item.image }}" alt="atra"></div>
                        <div class="title">{{item.title}}</div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        {% if contenidos_relacionados or referenciado_por %}
        <div class="recomendados lugares">
            <h4>Hoteles recomendados</h4>
            <ul>
                {% for item in contenidos_relacionados %}
                <li>
                    <a href="{{ item.url }}">
                        <div class="image"><img src="{{ item.image }}" alt="{{ item.title }}"></div>
                        <div class="title">{{ item.title }}</div>
                    </a>
                </li>
                {% endfor %}
                {% for item in referenciado_por %}
                <li>
                    <a href="{{ item.url }}">
                        <div class="image"><img src="{{ item.image }}" alt="{{ item.title }}"></div>
                        <div class="title">{{ item.title }}</div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        {% include "@visit_theme/includes/planifica.html.twig" %}
    </main>
</div>