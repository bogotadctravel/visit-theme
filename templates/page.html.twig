{# 1. Definición de IDs específicos (puedes añadir más aquí separados por comas) #}
{% set visit_node_ids = ['639'] %}
{% set is_specific_visit_id = node.id in visit_node_ids %}
{# 2. Verificación de campos y pertenencia al array de IDs #}
{% set is_mice = node.fields.field_evento_mice.value == '1' %}
{% set is_miceArticle = node.fields.field_articulo_mice.value == '1' %}
{% set is_specific_id = node.id in conecta_node_ids %}
{# 3. Listado de tipos de contenido de Visit #}
{% set visit_types = [
  'atractivos',
  'home_visit_2_0',
  'hoteles',
  'establecimientos',
  'rutas',
  'experiencias',
  'eventos',
  'page',
  'article',
  'pagina_agenda_de_eventos',
  'pagina-que-hacer'
] %}

{# 4. Lógica de decisión #}
{# Usamos Conecta si: es MICE, está en la lista de IDs, o NO es un bundle de Visit #}
{% set use_conecta = true %}

{# Si es un ID que debe usar Visit → forzamos Visit #}
{% if is_specific_visit_id %}
  {% set use_conecta = false %}
{% else %}
  {% if not is_mice and not is_miceArticle %}
    {% if node is defined and node.bundle in visit_types %}
      {% set use_conecta = false %}
    {% endif %}
  {% endif %}
{% endif %}

{# --- RENDER DEL HEADER --- #}
{% if use_conecta %}
  {% include "@visit_theme/includes/header_conecta.html.twig" %}
{% else %}
  {% include "@visit_theme/includes/header_visit.html.twig" %}
{% endif %}

<main id="main-content" class="site-content">
  {{ page.content }}
</main>

{# --- RENDER DEL FOOTER --- #}
{% if use_conecta %}
  {% include "@visit_theme/includes/footer_conecta.html.twig" %}
{% else %}
  {% include "@visit_theme/includes/footer_visit.html.twig" %}
{% endif %}