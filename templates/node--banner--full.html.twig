{% set img_desktop = null %}
{% set img_mobile = null %}

{% if node.field_banner.entity %}
  {% set img_desktop = file_url(node.field_banner.entity.fileuri) %}
{% endif %}

{% if node.field_imagen_mobile.entity %}
  {% set img_mobile = file_url(node.field_imagen_mobile.entity.fileuri) %}
{% endif %}

{% if img_desktop or img_mobile %}
<picture class="banner-picture">
  {% if img_mobile %}
  <source media="(max-width: 768px)" srcset="{{ img_mobile }}">
  {% endif %}
  <img
    src="{{ img_desktop ? img_desktop : img_mobile }}"
    alt="{{ node.field_banner.0.alt ? node.field_banner.0.alt : node.getTitle() }}"
    loading="lazy"
    style="width:100%;display:block;"
  >
</picture>
{% endif %}
