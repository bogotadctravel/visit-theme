<div class="atractivo restaurante-profile">
    <main>
        {% set banner_image = null %}
        {% if node.field_mainimg.entity %}
            {% set banner_image = file_url(node.field_mainimg.entity.fileuri) %}
        {% endif %}

        {% if banner_image %}
        <div class="banner" style="background-image: url('{{ banner_image }}');">
            <div class="container">
                <div class="text">
                    {# Categoría Gastronómica y Zona Gastronómica #}
                    <div class="foodie-badges" style="margin-bottom: 15px;">
                        {% if node.field_categoria_gastronomica|length > 0 %}
                            <span class="badge-alojamiento">{{ node.field_categoria_gastronomica.0.entity.name.value }}</span>
                        {% endif %}
                        {% if node.field_zonagast|length > 0 %}
                            <span class="badge-zona">📍 Zona: {{ node.field_zonagast.0.entity.name.value }}</span>
                        {% endif %}
                    </div>

                    <h1>{{ node.getTitle() }}</h1>
                    
                    <div class="comollegar">
                        {% if node.field_direccion.0.value is not empty %}
                            <p>📍 {{ node.field_direccion.0.value }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        <div class="flex">
            <div class="main-content">
                
                {% if node.field_picgallery|length > 0 %}
                    <div class="galeria-grid">
                        {% for item in node.field_picgallery|slice(0,5) %}
                            <a href="{{ file_url(item.entity.fileuri) }}" data-fancybox="gallery" data-caption="{{ item.title }}">
                                <img src="{{ file_url(item.entity.fileuri) }}" alt="{{ item.alt }}">
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if content.body is not empty %}
                    <div class="desc">
                        {{ content.body }}
                    </div>
                {% endif %}

                {% if node.field_recorrido_360.0.value is not empty %}
                    <div class="recorrido-360" style="margin: 40px 0;">
                        <h3 style="font-size: 24px; font-weight: 800; color: #1e293b; margin-bottom: 20px;">
                            Conoce el ambiente en 360°
                        </h3>
                        <div class="iframe-container" style="border-radius: 12px; overflow: hidden; height: 400px; box-shadow: 0 10px 20px rgba(0,0,0,0.1);">
                            {{ node.field_recorrido_360.0.value | raw }}
                        </div>
                    </div>
                {% endif %}

                {% if file_url(node.field_audio.entity.fileuri) is not empty %}
                    <div class="audio-player-box" style="margin: 30px 0; background: #f8fafc; padding: 20px; border-radius: 12px;">
                        <h4 style="margin-bottom: 10px; font-size: 16px; color: #1e293b;">🎧 Escuchar reseña gastronómica</h4>
                        <audio controls style="width: 100%;">
                            <source src="{{ file_url(node.field_audio.entity.fileuri) }}" type="audio/mpeg">
                        </audio>
                    </div>
                {% endif %}

                <div class="flexmap" style="margin-top: 40px; border-top: 1px solid #e2e8f0; padding-top: 30px;">
                    <h3 style="font-size: 24px; font-weight: 800; color: #1e293b; margin-bottom: 20px;">
                        Ubicación del establecimiento
                    </h3>
                    
                    {% if node.field_latlong.0.value is not empty %}
                        <div class="map" rel="noopener">
                            <iframe id="mapNode" width="100%" height="350" style="border:0; border-radius: 16px;" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" src="https://www.google.com/maps?q={{node.field_latlong.0.value}},{{node.field_latlong.1.value}}&z=15&output=embed"></iframe>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="sidebar-reserva">
                <div class="booking-card">

                    {# Rango de Precios #}
                    {% if node.field_rango_de_precios|length > 0 %}
                        <div class="price-range">
                            <span class="label">Rango de precios:</span>
                            <span class="value">{{ node.field_rango_de_precios.0.entity.name.value }}</span>
                        </div>
                    {% endif %}

                    {# Botones de Acción Principales (Menú y Reserva) #}
                    <div class="action-buttons" style="margin-bottom: 30px;">
                        {% if node.field_menulink.0.url is not empty %}
                            <a href="{{node.field_menulink.0.url}}" target="_blank" class="reservaLink menu-btn" style="margin-bottom: 10px;">
                                🍽️ Ver Menú Digital
                            </a>
                        {% endif %}

                        {% if node.field_linkreservas.0.url is not empty %}
                            <a href="{{node.field_linkreservas.0.url}}" target="_blank" class="reservaLink">
                                Reservar Mesa
                            </a>
                        {% endif %}
                    </div>

                    <h3>Información práctica</h3>

                    <ul class="quick-facts">
                        {% if node.field_horarios.0.value is not empty %}
                            <li>
                                <span class="icon">🕒</span> 
                                <div>
                                    <strong>Horarios</strong>
                                    <p>{{ node.field_horarios.0.value }}</p>
                                </div>
                            </li>
                        {% endif %}

                        {% if node.field_idioma_del_servicio|length > 0 %}
                            <li>
                                <span class="icon">🗣️</span> 
                                <div>
                                    <strong>Idiomas de atención</strong>
                                    <p>
                                        {% for item in node.field_idioma_del_servicio %}
                                            {{ item.entity.name.value }}{% if not loop.last %}, {% endif %}
                                        {% endfor %}
                                    </p>
                                </div>
                            </li>
                        {% endif %}
                    </ul>

                    <div class="tags-group">
                        {# Accesibilidad #}
                        {% if node.field_accesibilidad|length > 0 %}
                            <div class="tag-block">
                                <strong>Accesibilidad:</strong>
                                <div class="tag-container">
                                    {% for item in node.field_accesibilidad %}
                                        <span class="tag-item" style="background: #e0f2fe; color: #0284c7;">{{ item.entity.name.value }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        {# Recomendado para #}
                        {% if node.field_turpara|length > 0 %}
                            <div class="tag-block">
                                <strong>Ambiente ideal para:</strong>
                                <div class="tag-container">
                                    {% for item in node.field_turpara %}
                                        <span class="tag-item">{{ item.entity.name.value }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        {# Mercados Locales Relacionados #}
                        {% if node.field_mercados_locales_relaciona|length > 0 %}
                            <div class="tag-block">
                                <strong>Mercados aliados:</strong>
                                <div class="tag-container">
                                    {% for item in node.field_mercados_locales_relaciona %}
                                        <a href="{{ path('entity.node.canonical', {'node': item.entity.id}) }}" class="tag-item cat-tag">{{ item.entity.name.value }}</a>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>

                    {# Redes Sociales (Tu código SVG original adaptado al sidebar) #}
                    {% if node.field_profilelink|length > 0 %}
                        <div class="social-sidebar" style="margin-top: 25px; padding-top: 20px; border-top: 1px solid #f1f5f9; text-align: center;">
                            <strong style="display:block; margin-bottom:15px; font-size:13px; color:#64748b; text-transform:uppercase;">Síguenos en:</strong>
                            <div style="display: flex; gap: 10px; justify-content: center; align-items: center;">
                                {% for item in node.field_profilelink %}
                                    <a href="{{ item.url }}" target="_blank" aria-label="{{ item.title }}" style="transition: transform 0.2s;">
                                        {# Aquí va tu código SVG original de facebook, instagram, etc... #}
                                        {% if 'facebook' in item.uri %}
                                            <svg width="40" height="40" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="0.193" y="0.249" width="49.125" height="49" rx="24.5" fill="#f1f5f9" /><path d="M26.94 26.62H30.06L31.31 21.62H26.94V19.12C26.94 17.83 26.94 16.62 29.44 16.62H31.31V12.42C30.91 12.37 29.37 12.24 27.74 12.24C24.35 12.24 21.94 14.32 21.94 18.12V21.62H18.19V26.62H21.94V37.24H26.94V26.62Z" fill="#35498e" /></svg>
                                        {% elseif 'instagram' in item.uri %}
                                            <svg width="40" height="40" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="0.318" y="0.005" width="49.488" height="49.488" rx="24.74" fill="#f1f5f9" /><path d="M30.38 12.00H19.31C15.74 12.00 12.85 15.02 12.85 18.74V30.26C12.85 33.98 15.74 37.00 19.31 37.00H30.38C33.95 37.00 36.85 33.98 36.85 30.26V18.74C36.85 15.02 33.95 12.00 30.38 12.00Z" stroke="#35498e" stroke-width="2" stroke-miterlimit="10" /><path d="M24.85 31.00C28.16 31.00 30.85 28.31 30.85 25.00C30.85 21.69 28.16 19.00 24.85 19.00C21.53 19.00 18.85 21.69 18.85 25.00C18.85 28.31 21.53 31.00 24.85 31.00Z" stroke="#35498e" stroke-width="2" stroke-miterlimit="10" /><path d="M32.35 19.00C33.17 19.00 33.85 18.33 33.85 17.50C33.85 16.67 33.17 16.00 32.35 16.00C31.52 16.00 30.85 16.67 30.85 17.50C30.85 18.33 31.52 19.00 32.35 19.00Z" fill="#35498e" /></svg>
                                        {% elseif 'tiktok' in item.uri %}
                                            <svg width="40" height="40" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="0.5" y="0.5" width="49" height="49" rx="24.5" fill="#f1f5f9" /><g transform="translate(10, 8)"><path d="M16.65 1.02c1.63-0.02 3.26-0.01 4.88-0.02 0.05 2.03 0.87 3.85 2.18 5.21l-0.00-0.00c1.41 1.27 3.24 2.09 5.27 2.23v5.03c-1.91-0.04-3.71-0.48-5.33-1.24l0.08 0.03c-0.78-0.37-1.44-0.76-2.07-1.19l0.05 0.03c-0.01 3.64 0.01 7.29-0.02 10.93-0.10 1.85-0.71 3.54-1.70 4.95l0.02-0.03c-1.65 2.36-4.32 3.91-7.37 4.01c-0.12 0.00-0.26 0.00-0.41 0.00-1.73 0-3.34-0.48-4.72-1.31l0.04 0.02c-2.50-1.50-4.23-4.09-4.55-7.09l-0.00-0.04c-0.02-0.62-0.03-1.25-0.01-1.86 0.49-4.77 4.49-8.47 9.36-8.47 0.54 0 1.08 0.04 1.60 0.13l-0.05-0.00c0.02 1.84-0.05 3.69-0.05 5.54-0.42-0.15-0.91-0.24-1.42-0.24-1.86 0-3.45 1.19-4.04 2.86l-0.00 0.03c-0.13 0.42-0.21 0.91-0.21 1.42 0 0.20 0.01 0.41 0.03 0.61l-0.00-0.02c0.33 2.04 2.08 3.59 4.20 3.59 0.06 0 0.12-0.00 0.18-0.00h-0.00c1.46-0.04 2.73-0.83 3.45-1.99l0.01-0.01c0.26-0.37 0.45-0.82 0.51-1.31v-0.01c0.12-2.23 0.07-4.46 0.08-6.69 0.01-5.03-0.01-10.06 0.02-15.08z" fill="#35498e" /></g></svg>
                                        {% else %}
                                            <span style="font-size: 12px; color: #2563eb; text-decoration: underline;">Link</span>
                                        {% endif %}
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {# Contacto del Establecimiento #}
                    {% if node.field_telefono.0.value is not empty or node.field_correo.0.value is not empty or node.field_weblink.0.url is not empty %}
                        <div class="contact-card" style="margin-top: 20px; padding-top: 15px; border-top: 1px solid #f1f5f9;">
                            <strong style="display:block; margin-bottom:10px; font-size:13px; color:#64748b; text-transform:uppercase;">Contacto:</strong>
                            {% if node.field_telefono.0.value is not empty %}
                                <a href="tel:{{node.field_telefono.0.value}}" class="contact-link">📞 {{node.field_telefono.0.value}}</a><br>
                            {% endif %}
                            {% if node.field_correo.0.value is not empty %}
                                <a href="mailto:{{node.field_correo.0.value}}" class="contact-link">✉️ {{node.field_correo.0.value}}</a><br>
                            {% endif %}
                            {% if node.field_weblink.0.url is not empty %}
                                <a href="{{node.field_weblink.0.url}}" target="_blank" class="contact-link">🌐 Sitio Web</a>
                            {% endif %}
                        </div>
                    {% endif %}

                </div>
            </div>
        </div>

        {% if nodos_cercanos|length > 0 %}
        <div class="lugares">
            <h4>{{"ui.places_nearby"|t({'@place': node.getTitle()})}}</h4>
            <ul>
                {% for item in nodos_cercanos|shuffle|slice(0, 4) %}
                <li>
                    <a href="{{ path('entity.node.canonical', {'node': item.id}) }}">
                        <div class="image"><img src="{{item.image }}" alt="atra"></div>
                        <div class="title">{{item.title}}</div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        {% if contenidos_relacionados or referenciado_por %}
        <div class="recomendados lugares">
            <h4>También te podría gustar</h4>
            <ul>
                {% for item in contenidos_relacionados %}
                <li>
                    <a href="{{ item.url }}">
                        <div class="image"><img src="{{ item.image }}" alt="{{ item.title }}"></div>
                        <div class="title">{{ item.title }}</div>
                    </a>
                </li>
                {% endfor %}
                {% for item in referenciado_por %}
                <li>
                    <a href="{{ item.url }}">
                        <div class="image"><img src="{{ item.image }}" alt="{{ item.title }}"></div>
                        <div class="title">{{ item.title }}</div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        {% include "@visit_theme/includes/planifica.html.twig" %}
    </main>
</div>