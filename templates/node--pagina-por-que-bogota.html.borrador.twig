<style>
.about__header img {
    width: 50%;
    height: auto;
    margin: 15px auto;
    border-radius: 16px;
    object-fit: cover;
    box-shadow: 0 10px 30px rgba(0, 0, 0, .08);
}
.about__header p {
    font-size: 15px;
    margin-bottom: 5px;
    color: #444;
    line-height: 22px;
}
.about__header h2 {
    font-size: 27px;
    font-weight: 700;
    margin: 10px 0;
    line-height: 42px;
    position: relative;
}
</style>
<main>
  <section class="about">
    <div class="about__header">
      {{node.body.value|raw}}
    </div>
  </section>

  <section  class=" about__data" role="tablist" aria-label="Categorías de datos de Bogotá¡">
    <div class="data__header">
      <h2>Nuestros datos</h2>
    </div>
<div class="data-tabs"
     role="tablist"
     aria-label="Categorías de datos de Bogotá¡"
     data-carousel-indicators="about"
     style="    grid-template-columns: repeat(5, minmax(0, 1fr));"
     >
     

      {% for item in por_que_bogota %}
      {% if item.field_seccion == 'seccion_1'%}
  <button class="data-tab"
        type="button"
        role="tab"
        aria-selected="false"
        data-carousel-indicator
        data-carousel-target="about">
    <span class="data-tab__dot" aria-hidden="true"></span>
    <span class="data-tab__label">{{item.title}}</span>
  </button>
      {% endif %}


      {% endfor %}
    </div>
  </section>

  <section class="about__slider" aria-label="Indicadores clave de BogotÃ¡">
   <div class="about-slider" data-carousel data-carousel-id="about" style="    flex: 0 0 100%;
    display: grid;
    grid-template-columns: 680px;
    gap: clamp(1.25rem, 3vw, 3rem);
    padding-block: .5rem;
    height: max-content;
    align-items: center;
    justify-content: center;">
      <div class="about-slider__viewport" data-carousel-viewport>
        <div class="about-slider__track" data-carousel-track>
          {% for item in por_que_bogota %}
          {% if item.field_seccion == 'seccion_1'%}
          <article class="about-slide" data-carousel-item style="display: grid; grid-template-columns: 1fr; gap: 2rem;     align-items: flex-start;grid-template-rows: auto 1fr;">
            <img src="{{item.image}}" alt="{{item.title}}" />
            <div class="about-slide__content">
              <h3>{{item.title}}</h3>
              {{ item.body|raw }}
              <a class="about-slide__link" href="/venues">Explora nuestras locaciones</a>
            </div>
          </article>
{% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="about-slider__nav">
        <button class="about-slider__arrow" type="button" data-carousel-prev aria-label="Anterior">
          &#10094;
        </button>
        <button class="about-slider__arrow" type="button" data-carousel-next aria-label="Siguiente">
          &#10095;
        </button>
      </div>
    </div>
  </section>
