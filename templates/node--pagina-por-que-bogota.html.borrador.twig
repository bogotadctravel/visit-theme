 <section class="about-highlight" style="  margin-top: clamp(2.5rem, 6vw, 4rem);
  display: grid;

  grid-template-columns: 1fr;
  max-width: 768px;" aria-label="Historias de impacto">
   {% for item in por_que_bogota %}
          {% if item.field_seccion == 'seccion_2'%}
          <article class="highlight-slide">
            <div class="highlight-slide__copy">
            <img src="{{item.image}}" alt="{{item.title}}" width="100%" height="100%" style="border-radius: 16px;" />
              <h3>{{item.title}}</h3>
              {{ item.body|raw }}
            </div>
            <div class="highlight__image">
       
