<div class="product">
    <div class="banner" style="background-image: url({{file_url(term.field_imagen_principal.entity.fileuri)}});">
        <div class="container">

            <div class="text">
                <h2>Visit Bogotá</h2>
                <h1>{{ term.name.value }}</h1>
                {{ term.description.value|raw }}
            </div>
        </div>
    </div>
    {% if atractivos is not empty %}
    <ul class="grid-atractivos container">
        {% for item in atractivos|shuffle %}
        <li class="card" data-aos="zoom-in" data-aos-delay="300"><a href="{{ path('entity.node.canonical', {'node': item.id}) }}">
                <div class="image">
                    <img src="{{item.image}}" alt="blog title">
                </div>
                <div class="title">
                    {{item.title}}
                </div>
            </a></li>
        {% endfor %}
    </ul>
    {% endif %}


    {% if eventos is not empty %}
    <div class="eventos" data-aos="fade-right">
        <h4>{{"ui.events_in_bogota"|t}}{{ term.name.value }} en Bogotá</h4>
        <section class="splide" aria-label="Splide Basic HTML Example">
            <div class="splide__track">
                <ul class="splide__list grid-events ">
                    {% for item in eventos|shuffle %}
                    <li class="splide__slide"> <a href="{{ path('entity.node.canonical', {'node': item.id}) }}"
                            style="background-image: url({{item.image}});">
                            <div class="tag">{{ term.name.value }}</div>
                            <span class="title"> {{item.title}}</span>
                            <div class="date"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path
                                        d="M5.33333 1.33325V3.99992M10.6667 1.33325V3.99992M14 9.33325V3.99992C14 3.6463 13.8595 3.30716 13.6095 3.05711C13.3594 2.80706 13.0203 2.66659 12.6667 2.66659H3.33333C2.97971 2.66659 2.64057 2.80706 2.39052 3.05711C2.14048 3.30716 2 3.6463 2 3.99992V13.3333C2 13.6869 2.14048 14.026 2.39052 14.2761C2.64057 14.5261 2.97971 14.6666 3.33333 14.6666H8.66667M2 6.66658H14M10.6667 13.3333L12 14.6666L14.6667 11.9999"
                                        stroke="white" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round" />
                                </svg>
                                OCT 9 - 13
                            </div>
                            <div class="place"><svg width="298" height="16" viewBox="0 0 298 16" fill="none"
                                    xmlns="http://www.w3.org/2000/svg">
                                    <path
                                        d="M13.3333 6.66659C13.3333 9.99525 9.64063 13.4619 8.40063 14.5326C8.28511 14.6194 8.14449 14.6664 7.99996 14.6664C7.85543 14.6664 7.71481 14.6194 7.59929 14.5326C6.35929 13.4619 2.66663 9.99525 2.66663 6.66659C2.66663 5.2521 3.22853 3.89554 4.22872 2.89535C5.22892 1.89516 6.58547 1.33325 7.99996 1.33325C9.41445 1.33325 10.771 1.89516 11.7712 2.89535C12.7714 3.89554 13.3333 5.2521 13.3333 6.66659Z"
                                        stroke="#FFFBFB" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round" />
                                    <path
                                        d="M7.99996 8.66659C9.10453 8.66659 9.99996 7.77115 9.99996 6.66659C9.99996 5.56202 9.10453 4.66659 7.99996 4.66659C6.89539 4.66659 5.99996 5.56202 5.99996 6.66659C5.99996 7.77115 6.89539 8.66659 7.99996 8.66659Z"
                                        stroke="#FFFBFB" stroke-width="2" stroke-linecap="round"
                                        stroke-linejoin="round" />

                                </svg>
                                {{item.fields.field_lugar_del_evento.value}}
                            </div>
                        </a></li>
                    {% endfor %}
                </ul>
            </div>
        </section>
    </div>
    {% endif %}
    {% if rutas is not empty %}
    <div class="rutas">
        <div class="container">
            <h3>{{"ui.tourist_routes"|t}}</h3>
            <ul>
                {% for item in rutas|shuffle|slice(0, 4) %}
                <li class="card">
                    <a href="{{ path('entity.node.canonical', {'node': item.id}) }}">
                        <div class="image">

                            <img src="{{item.image}}"
                                alt=" {{item.title}}">
                        </div>
                        <div class="title">
                            {{item.title}}
                        </div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>

    {% endif %}


    {% if article is not empty %}
    <div class="blog" data-aos="fade-down">
        <h5>{{"ui.recent_posts"|t}}</h5>
        <ul class="grid-blogs container">
            {% for item in article|shuffle|slice(0, 6) %}
            <li><a href="{{ path('entity.node.canonical', {'node': item.id}) }}">
                    <div class="image">

                        <img src="{{item.image}}" alt="blog title">
                    </div>
                    <div class="title">
                        {{item.title}}
                    </div>
                    <div class="tag">{{item.categoria.name}}</div>
                </a></li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}
    {% if experiencias is not empty %}

    <div class="rutas">
        <div class="container">
            <h3>Experiencias relacionadas</h3>
            <ul>
                {% for item in experiencias|shuffle|slice(0, 4) %}
                <li class="card">
                    <a href="{{ path('entity.node.canonical', {'node': item.id}) }}">
                        <div class="image">

                            <img src="{{item.image}}" alt="blog title">
                        </div>
                        <div class="title">
                            {{item.title}}
                        </div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>
    {% endif %}
    <div class="planifica-container" data-aos="fade-right">
        {% include "@visit_theme/includes/planifica.html.twig" %}
    </div>
</div>