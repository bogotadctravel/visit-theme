    <main>
        <section class="places" id="places">
            <div class="places__header">
                <h1>{{"ui.ideal_place_intro"|trans}}</h1>
            </div>
            <div class="places__search-card">
                <div class="places__search-field places__search-field--range">
                    <span class="places__search-label">{{"ui.max_capacity"|trans}}</span>
                    <div class="places-range" data-range-control>
                        <output
                            class="places-range__bubble"
                            for="places-capacity"
                            aria-live="polite"
                        >
                            <span data-range-value>0</span>
                        </output>
                        <input
                            type="range"
                            id="places-capacity"
                            name="capacity"
                            min="0"
                            max="10000"
                            step="10"
                            value="0"
                            aria-label="Aforo máximo en auditorio"
                        />
                    </div>
                </div>

                <label class="places__search-field">
                    <span class="places__search-label">{{"ui.location"|trans}}</span>
                    <div class="places-input places-input--select">
                        <span class="places-input__icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                                <circle cx="11" cy="11" r="6" />
                                <path d="m16.5 16.5 3.5 3.5" stroke-linecap="round" />
                            </svg>
                        </span>
                        <select name="location" aria-label="Ubicación">
                            <option value="">{{"ui.select_location"|trans}}</option>
                        
                             {% for item in zonas_de_la_ciudad %}
                            <option value="{{item.tid}}">{{ item.name }}</option>
                            {% endfor %}
                        </select>
                        <span class="places-input__icon places-input__icon--trailing" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                                <path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    </div>
                </label>
                <label class="places__search-field">
                    <span class="places__search-label">{{"ui.venue_type"|trans}}</span>
                    <div class="places-input places-input--select">
                        <span class="places-input__icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                                <circle cx="11" cy="11" r="6" />
                                <path d="m16.5 16.5 3.5 3.5" stroke-linecap="round" />
                            </svg>
                        </span>
                        <select name="type" aria-label="Tipo de venue">
                        <option value="">{{"ui.select_venue_type"|trans}}</option>
                             {% for item in tipo_de_venue %}
                            <option value="{{item.tid}}">{{ item.name }}</option>
                            {% endfor %}
                        </select>
                        <span class="places-input__icon places-input__icon--trailing" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                                <path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                        </span>
                    </div>
                </label>
            </div>

            <div class="places__grid" aria-live="polite">
           
            {% for item in venues %}
              {% set zonas = item.field_turzone %}
        {% set zonas_tids = zonas|map(v => v.tid)|join(',') %}


                <a class="place-card" style="position: relative;" href="{{item.url}}" data-capacity="{{ item.field_aforo_maximo_en_auditorio }}" data-location="{{ zonas_tids }}" data-type="{{ item.field_tipo_de_venue.tid  }}">
                    <div class="place-card__media place-card__media--a" aria-hidden="true" style="background-image: url({{item.image}});"></div>
                    <div class="place-card__body">
                        <h3 class="place-card__title">{{ item.title }}</h3>
                    </div>
                      {% if item.field_aprobado_marca_ciudad == '1' %}
                    <div class="marca" style="position: absolute;top: 130px;right: 0;width: 160px;height: 50px;">
                    <img src="/{{ directory }}/images/marcaciudad.png" alt="Marca de la ciudad"  width="100%"/>
                    </div>
                    {% endif %}
                </a>
            {% endfor %}
            </div>
        </section>
    </main>