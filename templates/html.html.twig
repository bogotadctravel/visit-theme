{#
/**
 * @file
 * Theme override for the basic structure of a single Drupal page.
 */
#}

<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>
    <head-placeholder token="{{ placeholder_token }}">
    <title>{{ head_title|safe_join(' | ') }}</title>

    {# ── Resource hints (P8: network) ── #}
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="dns-prefetch" href="https://www.googletagmanager.com">
    <link rel="dns-prefetch" href="https://unpkg.com">

    {# ── Preload critical font (P7) ── #}
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap">

    {# ── GTM (deduplicated, deferred-friendly) ── #}
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-M7XH5JV');</script>

    <css-placeholder token="{{ placeholder_token }}">
    <js-placeholder token="{{ placeholder_token }}">
    <style>
      div#block-visit-theme-breadcrumbs ol{display:flex;gap:1rem;padding:1rem;border-bottom:1px solid #e7e5e5}
      div#block-visit-theme-breadcrumbs ol li::marker{display:none;content:"» "}
      div#block-visit-theme-breadcrumbs ol li:first-child::marker{content:""}
      div#block-visit-theme-breadcrumbs ol li:last-child{font-weight:bold}
      div#block-visit-theme-breadcrumbs ol a:hover{text-decoration:underline}
    </style>
  </head>

  <body{{ attributes }}>

    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M7XH5JV"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    {{ page_top }}
    {{ page }}
    {{ page_bottom }}

    <js-bottom-placeholder token="{{ placeholder_token }}">
    <script>
      (function(){
        var key="ref";
        var url=new URL(window.location);
        var v=url.searchParams.get(key)||sessionStorage.getItem(key);
        if(v){
          sessionStorage.setItem(key,v);
          if(!url.searchParams.get(key)){
            url.searchParams.set(key,v);
            window.history.replaceState({},'',url);
          }
        }
      })();
      /* Auto lazy-load: any img without loading attr → lazy + async decode (skip first viewport candidates with fetchpriority) */
      (function(){
        var imgs=document.querySelectorAll('img:not([loading])');
        for(var i=0;i<imgs.length;i++){
          var im=imgs[i];
          if(im.getAttribute('fetchpriority')==='high')continue;
          im.setAttribute('loading','lazy');
          if(!im.hasAttribute('decoding'))im.setAttribute('decoding','async');
        }
      })();
    </script>
  </body>
</html>
