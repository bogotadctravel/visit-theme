<div class="product">
    <div class="banner" style="background-image: url({{file_url(node.field_mainimg.entity.fileuri)}});">
        <div class="container">
            <div class="text">
                <h1>Experiencias Turísticas</h1>
            </div>
        </div>
    </div>
    <main>
        <div class="container">
            {# 1. Formulario de Filtros #}
            <form id="filter-tool" class="filters-form" method="GET" action="">
                <span>
                    <label for="filter_name">Nombre</label>
                    {# 1. Agregamos el value dinámico #}
                    <input type="text" id="filter_name" name="filter_name" placeholder="Buscar por nombre..."
                        value="{{ current_filter_name }}">
                </span>
                <span>
                    <label for="filter_cat">Categoría</label>
                    <select id="filter_cat" name="filter_cat">
                        {# 2. Condicionamos la opción "Todas" #}
                        <option value="all" {% if current_filter_cat=='all' or current_filter_cat is empty %}selected{%
                            endif %}>Todas</option>

                        {% for cat in taxonomy('categorias_turisticas') %}
                        {# 3. Condicionamos si la categoría actual coincide con la iteración #}
                        <option value="{{ cat.tid }}" {% if current_filter_cat==cat.tid %}selected{% endif %}>{{
                            cat.name }}</option>
                        {% endfor %}
                    </select>
                </span>
                <button type="submit">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    Buscar
                </button>
            </form>

            {# 2. Contenedor y Loop #}
            <ul class="grid-atractivos container" id="grid-items">
                {% for item in experiencias %} {# Si es el template 835, cambia 'rutas' por 'experiencias' #}
                {# Atributos de datos para el JS #}
                <li class="card filterable-item" data-name="{{ item.title|lower }}"
                    data-cat="{{ item.categoria.tid ?? '' }}" data-aos="zoom-in" data-aos-delay="300">
                    <a href="{{ item.url }}">
                        <div class="image">
                            <img src="{{ item.image }}" alt="{{ item.title }}">
                        </div>
                        <div class="title">
                            {{ item.title }}
                        </div>
                    </a>
                </li>
                {% endfor %}
            </ul>

            {# 3. Paginador Nativo de Drupal #}
            {% if pager_experiencias %}
            <div class="pager-container">
                {{ pager_experiencias }}
            </div>
            {% endif %}
        </div>
    </main>
</div>