</style>
    <div class="ui-overlay">
     <img src="/{{directory}}/images/porB.svg" alt="Scroll Down" class="abImg">
        <div class="scroll-indicator">
           
            <img src="/{{directory}}/images/downArr.svg" alt="Scroll Down" class="shake-vertical">
        </div>
        <div class="reading-progress-bar"></div>
    </div>

    <main id="app">
    
        {% for item in por_que_bogota %}
        <section class="slide">
            <div class="slide__image">
                <img src="{{item.image}}"
                    alt="{{item.title}}">
            </div>
            <div class="slide__content">
                <div class="content-wrapper">
                    <h2 class="animate-text">{{item.title}}</h2>
                   {{ item.body|raw }}
                </div>
            </div>
        </section>
        {% endfor %}
    </main>

    <script src="/{{directory}}/js/gsap.min.js"></script>
    <script src="/{{directory}}/js/ScrollTrigger.min.js"></script>
    <script src="/{{directory}}/js/Observer.min.js"></script>
<script>
    gsap.registerPlugin(ScrollTrigger, Observer);

    let mm = gsap.matchMedia();


    // --- LÓGICA PARA ESCRITORIO ---
    mm.add("(min-width: 769px)", () => {
        let sections = document.querySelectorAll(".slide");
        let currentIndex = 0;
        let animating = false;

        gsap.set(".ui-overlay", { autoAlpha: 0 });
        gsap.set(sections, { autoAlpha: 0, zIndex: 1 });
        gsap.set(sections[0], { autoAlpha: 1, zIndex: 2 });
        animarEntrada(sections[0], 0);

        // Función para actualizar la barra de progreso
        function updateProgressBar(content) {
            if (content) {
                const totalHeight = content.scrollHeight - content.clientHeight;
                const progress = (content.scrollTop / totalHeight) * 100;
                gsap.to(".reading-progress-bar", { height: `${progress}%`, duration: 0.2 });
            }
        }

        function gotoSection(index, direction) {
            if (animating) return;
            animating = true;

            let fromSection = sections[currentIndex];
            let toSection = sections[index];


            let tl = gsap.timeline({
                onComplete: () => { animating = false; }
            });

            tl.to(fromSection, {
                autoAlpha: 0,
                y: direction === 1 ? -50 : 50,
                duration: 0.8,
                ease: "power2.inOut",
                zIndex: 1
            });

            gsap.set(toSection, { y: direction === 1 ? 50 : -50, zIndex: 2 });

            tl.to(toSection, {
                autoAlpha: 1,
                y: 0,
                duration: 0.8,
                ease: "power2.out"
            }, "-=0.4");

            animarEntrada(toSection, "-=0.6", tl);
            currentIndex = index;
            gsap.set(".reading-progress-bar", { height: "0%" });
        }

        function animarEntrada(section, delayStr = "", timeline = null) {
            let img = section.querySelector(".slide__image img");
            let texts = section.querySelectorAll(".animate-text");
            let content = section.querySelector(".slide__content");
            
            // ¡NUEVO! Resetear el scroll interno al inicio del contenedor
            if(content) content.scrollTop = 0;

            let tl = timeline || gsap.timeline();

            tl.fromTo(img,
                { scale: 1.1, autoAlpha: 0 },
                { scale: 1, autoAlpha: 1, duration: 1.2, ease: "power2.out" },
                delayStr
            );

            tl.fromTo(texts,
                { y: 40, autoAlpha: 0 },
                { y: 0, autoAlpha: 1, duration: 0.8, stagger: 0.1, ease: "power2.out" },
                "-=0.8"
            );
        }

        function lockScroll() {
            if (!observer.isEnabled) {
                observer.enable();
                gsap.to(".ui-overlay", { autoAlpha: 1, duration: 0.3 });
            }
        }

        function unlockScroll(direction) {
            observer.disable();
            gsap.to(".ui-overlay", { autoAlpha: 0, duration: 0.3 });
            window.scrollBy(0, direction === 'up' ? -20 : 20);
        }

// --- DENTRO DEL mm.add("(min-width: 769px)", ... ---

let observer = Observer.create({
    target: window,
    type: "wheel,touch,pointer",
    wheelSpeed: 1,
    tolerance: 10, // Bajamos la tolerancia para que responda más rápido pero suave
    preventDefault: true,
    onDown: (self) => {
        if (animating) return;
        let content = sections[currentIndex].querySelector('.slide__content');
        if (content && content.scrollHeight > content.clientHeight) {
            let isAtBottom = Math.ceil(content.scrollTop + content.clientHeight) >= content.scrollHeight - 5;
            
            if (!isAtBottom) {
                // Scroll interno SUAVE en lugar de salto brusco
                gsap.to(content, {
                    scrollTop: content.scrollTop + 150, // Cantidad de scroll
                    duration: 0.4,
                    ease: "power1.out"
                });
                return;
            }
        }
        gsap.to(content, {
            scrollTop: content.scrollTop + 150,
            duration: 0.4,
            ease: "power1.out",
            onUpdate: () => updateProgressBar(content) // <--- Añade esto
        });

        // Si ya llegamos al fondo, pasamos al siguiente slide
        if (currentIndex < sections.length - 1) {
            gotoSection(currentIndex + 1, 1);
        } else {
            unlockScroll('down');
        }
    },
    onUp: (self) => {
        if (animating) return;

        let content = sections[currentIndex].querySelector('.slide__content');
        
        if (content && content.scrollTop > 5) {
            // Scroll interno SUAVE hacia arriba
            gsap.to(content, {
                scrollTop: content.scrollTop - 150,
                duration: 0.4,
                ease: "power1.out"
            });
            return;
        }

        if (currentIndex > 0) {
            gotoSection(currentIndex - 1, -1);
        } else {
            unlockScroll('up');
        }
    }
});
        
        observer.disable();

        ScrollTrigger.create({
            trigger: "#app",
            start: "top top",
            end: "+=50",
            onEnter: (self) => {
                window.scrollTo(0, self.start);
                lockScroll();
            },
            onEnterBack: (self) => {
                window.scrollTo(0, self.start);
                lockScroll();
            }
        });

        return () => { 
            gsap.set(sections, { clearProps: "all" }); 
            observer.kill();
        };
    });

    // --- LÓGICA PARA MÓVILES ---
    mm.add("(max-width: 768px)", () => {
        let sections = document.querySelectorAll(".slide");
        gsap.set(".ui-overlay", { display: "none" });

        sections.forEach(section => {
            let img = section.querySelector(".slide__image img");
            let texts = section.querySelectorAll(".animate-text");

            gsap.from(img, {
                scrollTrigger: { trigger: section, start: "top 80%" },
                scale: 1.1, autoAlpha: 0, duration: 1, ease: "power2.out"
            });

            gsap.from(texts, {
                scrollTrigger: { trigger: section, start: "top 70%" },
                y: 40, autoAlpha: 0, duration: 0.8, stagger: 0.1, ease: "power2.out"
            });
        });
    });
</script>