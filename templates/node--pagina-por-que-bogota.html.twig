        {% set seccion2 = por_que_bogota|filter(item => item.field_seccion == 'seccion_2') %}

{% if seccion2 is not empty %}
 <section class="about-highlight" aria-label="Historias de impacto">
    <div class="highlight-slider" data-carousel>
      <button class="highlight-slider__arrow highlight-slider__arrow--prev" type="button" data-carousel-prev
        aria-label="Anterior">
        &#10094;
      </button>
      <div class="highlight-slider__viewport" data-carousel-viewport>
        <div class="highlight-slider__track" data-carousel-track>
          {% for item in por_que_bogota %}
          {% if item.field_seccion == 'seccion_2'%}
          <article class="highlight-slide" data-carousel-item>
            <div class="highlight-slide__copy">
              <h3>{{item.title}}</h3>
              {{ item.body|raw }}
            </div>
            <div class="highlight__image">
       <img src="{{item.image}}" alt="{{item.title}}" />
    </div>
          </article>
{% endif %}
          {% endfor %}
        </div>
      </div>
      <button class="highlight-slider__arrow highlight-slider__arrow--next" type="button" data-carousel-next
        aria-label="Siguiente">
        &#10095;
      </button>
    </div>
    
  </section>
{% endif %}

 
</main>