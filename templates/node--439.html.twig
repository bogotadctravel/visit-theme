<div class="events__body">
  <main class="events-main">
    <section class="events__page" id="events">
      <div class="events__header">
      <h1>{{"ui.successful_events_bogota"|trans}}</h1>
        <p>{{"ui.swipe_more"|trans}}</p>
      </div>
      <div class="events__filters">
       

      </div>
      <div class="events__grid">
        {% for item in casos_de_exito|reverse %}
        <a
          href="{{ item.url }}"
          class="event-card"
          data-carousel-item
        >
          <div
            class="event-card__media"
            aria-hidden="true"
            style="background-image: url({{item.field_fotos.0}});"
          ></div>
          <div class="event-card__content">
            <h3>{{ item.title }}</h3>
            <div class="event-card__meta">

            </div>
          </div>
        </a>
        {% endfor %}
      </div>
    </section>
  </main>
</div>

