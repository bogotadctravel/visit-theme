<div class="article blog-post">
    
    {# 1. Configuración de la Imagen de Portada #}
    {% set banner_image = null %}
    {% if node.field_cover.entity %}
        {% set banner_image = file_url(node.field_cover.entity.fileuri) %}
    {% elseif node.field_mainimg.entity %}
        {% set banner_image = file_url(node.field_mainimg.entity.fileuri) %}
    {% elseif node.field_image.entity %}
        {% set banner_image = file_url(node.field_image.entity.fileuri) %}
    {% endif %}

    {# 2. Cabecera del Artículo (Título e Intro) #}
    <header class="blog-header">
        <div class="container-narrow">
            
            {# Categorías #}
            {% if node.field_turcat|length > 0 %}
                <div class="blog-categories">
                    {% for item in node.field_turcat %}
                        <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': item.entity.id}) }}" class="cat-badge">
                            {{ item.entity.name.value }}
                        </a>
                    {% endfor %}
                </div>
            {% endif %}

            <h1>{{ node.getTitle() }}</h1>

            {# Introducción (Lead paragraph) #}
            {% if node.field_introduccion.0.value is not empty %}
                <p class="lead-intro">
                    {{ node.field_introduccion.0.value }}
                </p>
            {% endif %}
        </div>
    </header>

    {# 3. Imagen Principal Panorámica #}
    {% if banner_image %}
    <div class="blog-banner">
        <img src="{{ banner_image }}" alt="{{ node.getTitle() }}">
    </div>
    {% endif %}

    {# 4. Cuerpo del Artículo #}
    <main class="blog-content">
        <div class="container-narrow content-body">
            {{ content.body }}
        </div>

        {# 5. Pie del Artículo (Etiquetas y Recomendado para) #}
        <div class="container-narrow">
            <footer class="blog-footer">
                {% if node.field_tags|length > 0 or node.field_turpara|length > 0 %}
                    <div class="post-tags">
                        <strong>Temas relacionados:</strong>
                        <div class="tag-container">
                            {% for item in node.field_tags %}
                                <span class="tag-item">{{ item.entity.name.value }}</span>
                            {% endfor %}
                            
                            {% for item in node.field_turpara %}
                                <span class="tag-item outline">{{ item.entity.name.value }}</span>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </footer>
        </div>
    </main>

    {# 6. Contenido Relacionado #}
    {% if contenidos_relacionados or referenciado_por %}
    <section class="related-content lugares">
        <div class="container">
            <h4>Más artículos y lugares recomendados</h4>
            <ul class="grid-relacionados">
                {% for item in contenidos_relacionados %}
                <li>
                    <a href="{{ item.url }}">
                        <div class="image">
                            <img src="{{ item.image }}" alt="{{ item.title }}">
                        </div>
                        <div class="title">{{ item.title }}</div>
                    </a>
                </li>
                {% endfor %}
                
                {% for item in referenciado_por %}
                <li>
                    <a href="{{ item.url }}">
                        <div class="image">
                            <img src="{{ item.image }}" alt="{{ item.title }}">
                        </div>
                        <div class="title">{{ item.title }}</div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
    </section>
    {% endif %}

</div>

{# Script original mantenido para las leyendas de imágenes #}
<script>
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.content-body img').forEach(img => {
        if (img.closest('figure')) return;
        if (img.closest('.image-wrapper')) return;

        const text = img.getAttribute('title') || img.getAttribute('alt');
        if (!text) return;

        const wrapper = document.createElement('div');
        wrapper.classList.add('image-wrapper');

        const caption = document.createElement('div');
        caption.classList.add('image-caption');
        caption.textContent = text;

        img.parentNode.insertBefore(wrapper, img);
        wrapper.appendChild(img);
        wrapper.appendChild(caption);
    });
});
</script>