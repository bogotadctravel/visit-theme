<style>
.article .banner{
    overflow: hidden;
    position: relative;
}
.article .banner h1{
    position: relative;
    z-index: 10;
}
.article .banner::after{
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5); /* Ajusta la opacidad según tus necesidades */
}
</style>
  <div class="article">
    <div class="banner" style="background-image: url({{file_url(node.field_cover.entity.fileuri)}});">
        <h1>{{ node.getTitle() }}</h1>
    </div>
      <div class="content">
          {{ content.body }}
      </div>
  </div>