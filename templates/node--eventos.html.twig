<style>
.date-wrapper {
  display: flex;
  align-items: center;
  gap: 15px;
  font-family: 'Arial', sans-serif; /* Cambia por la fuente de tu sitio */
}

.date-block {
  display: flex;
  align-items: center;
  gap: 10px;
}

.date-day {
  color: #314059; /* Azul exacto */
  font-size: 48px;
  font-weight: 800;
  line-height: 1;
}

.date-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.date-top {
  color: #314059;
  font-weight: 700;
  font-size: 18px;
  text-transform: uppercase;
  line-height: 1.2;
}

.date-bottom {
  color: #909090; /* Gris sutil */
  font-weight: 400;
  font-size: 15px;
  text-transform: uppercase;
  line-height: 1.2;
}

.date-divider {
  margin: 0 2px;
  opacity: 0.8;
}

.date-separator-dash {
  font-size: 30px;
  color: #314059;
  font-weight: bold;
}
</style>
{% set mice = node.field_evento_mice.0.value == '1' %}

{% if mice %}
<div class="events__body">
  <main class="events-main">
    <section class="events__successful" id="eventsSuccesful">
      <div class="events__successful-header">
        <h1>{{ node.getTitle() }}</h1>
        {{ content.body }}
      </div>
      <div class="events__successful-details">
        <div class="details__recommended">
          <p><strong>Recomendado para:</strong></p>
          <div class="events__filters details">
            {% for term in node.field_turpara %}
            <button type="button">{{ term.entity.name.value }}</button>
            {% endfor %}
          </div>
        </div>
        <div class="details__program">
          <p><strong>Programate:</strong></p>
          <div class="event-card__meta">
            <span class="event-card__meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  d="M6.75 3a.75.75 0 0 0 0 1.5H7.5V6h-3A2.25 2.25 0 0 0 2.25 8.25v10.5A2.25 2.25 0 0 0 4.5 21h15a2.25 2.25 0 0 0 2.25-2.25V8.25A2.25 2.25 0 0 0 19.5 6h-3V4.5h.75a.75.75 0 0 0 0-1.5h-3a.75.75 0 0 0 0 1.5h.75V6h-6V4.5h.75a.75.75 0 0 0 0-1.5h-3Zm-1.5 6.75A.75.75 0 0 1 6 9h12a.75.75 0 0 1 .75.75v8.25c0 .414-.336.75-.75.75H6a.75.75 0 0 1-.75-.75Z" />
              </svg>
              {% set meses = {
              'Jan': 'Ene', 'Feb': 'Feb', 'Mar': 'Mar',
              'Apr': 'Abr', 'May': 'May', 'Jun': 'Jun',
              'Jul': 'Jul', 'Aug': 'Ago', 'Sep': 'Sept',
              'Oct': 'Oct', 'Nov': 'Nov', 'Dec': 'Dic'
              } %}

              {% set raw_inicio = node.field_fecha_de_inicio.0.value %}
              {% set raw_fin = node.field_fecha_de_finalizacion.0.value %}

              {% set mes_en = raw_inicio|date('M') %}
              {% set mes_es = meses[mes_en] %}
              {% set dia_inicio = raw_inicio|date('j') %}
              {% set dia_fin = raw_fin|date('j') %}

              <span>{{ mes_es }} {{ dia_inicio }} - {{ dia_fin }}</span>

            </span>
            <span class="event-card__meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              {{ node.field_lugar_del_evento.0.value }}
            </span>
          </div>
        </div>
      </div>
      <div class="events__successful-media">
        {% for item in node.field_picgallery %}
        {% set url = file_url(item.entity.uri.value) %}
        <img src="{{ url }}" alt="">
        {% endfor %}

      </div>
      {# <div class="events__succesful-text">
        {% if node.field_incluir_disclaimer.0.value %}
        <p>
          DISCLAIMER
        </p>
        {% endif %}
      </div> #}
    </section>
  </main>
</div>
{% else %}
<div class="intern_event">
  <main>
    <div class="container">
      <div class="info">
        <div class="image">
          <img src="{{file_url(node.fields.field_mainimg.0.entity.uri.value)}}" alt="obra">
        </div>
        <div class="text">


          <h1> {{ node.getTitle() }}</h1>
          <small>{{ node.field_lugar_del_evento.0.value }}</small>

{# 1. Mapeo de traducciones #}
{% set meses = {
  'Jan': 'ENE', 'Feb': 'FEB', 'Mar': 'MAR', 'Apr': 'ABR', 
  'May': 'MAY', 'Jun': 'JUN', 'Jul': 'JUL', 'Aug': 'AGO', 
  'Sep': 'SEPT', 'Oct': 'OCT', 'Nov': 'NOV', 'Dec': 'DIC'
} %}

{% set dias_semana = {
  'Mon': 'LUN', 'Tue': 'MAR', 'Wed': 'MIÉ', 'Thu': 'JUE', 
  'Fri': 'VIE', 'Sat': 'SÁB', 'Sun': 'DOM'
} %}

{# 2. Extracción de datos #}
{% set raw_inicio = node.field_fecha_de_inicio.0.value %}
{% set raw_fin = node.field_fecha_de_finalizacion.0.value %}
{% set hora_inicio = node.field_hora_de_inicio_del_evento.0.value %}

{# 3. Formateo de variables de inicio #}
{% set dia_inicio = raw_inicio|date('j') %}
{% set mes_inicio = meses[raw_inicio|date('M')] %}
{% set anio_inicio = raw_inicio|date('Y') %}
{% set sem_inicio = dias_semana[raw_inicio|date('D')] %}

<div class="date-wrapper">
  {# Bloque de Inicio #}
  <div class="date-block">
    <div class="date-day">{{ dia_inicio }}</div>
    <div class="date-info">
      <div class="date-top">
        <span class="date-month">{{ mes_inicio }}</span>
        <span class="date-divider">/</span>
        <span class="date-year">{{ anio_inicio }}</span>
      </div>
      <div class="date-bottom">
        <span class="date-weekday">{{ sem_inicio }}</span>
        <span class="date-divider">/</span>
        <span class="date-time">{{ hora_inicio }}</span>
      </div>
    </div>
  </div>

  {# Rango (si el día es distinto) #}
  {% if raw_inicio|date('Y-m-d') != raw_fin|date('Y-m-d') and raw_fin is not empty %}
    <div class="date-separator-dash">-</div>
    
    {% set dia_fin = raw_fin|date('j') %}
    {% set mes_fin = meses[raw_fin|date('M')] %}
    {% set anio_fin = raw_fin|date('Y') %}

    <div class="date-block">
      <div class="date-day">{{ dia_fin }}</div>
      <div class="date-info">
        <div class="date-top">
          <span class="date-month">{{ mes_fin }}</span>
          <span class="date-divider">/</span>
          <span class="date-year">{{ anio_fin }}</span>
        </div>
      </div>
    </div>
  {% endif %}
</div>
          {{ content.body }}
          <div class="list">
            <ul style="list-style: none; padding: 0;flex-direction: column;gap:10px;">
              <li>
                <strong>Categoría de evento </strong>
                <div class="tag-container">
                  {% for item in node.field_categoria_de_evento %}
                  <span class="tag-item">{{ item.entity.name.value }}</span>
                  {% endfor %}
                </div>
              </li>
               {% if node.field_turcat|length > 0 %}
              <li>
                <strong>Categoría relacionada </strong>
                <div class="tag-container">
                  {% for item in node.field_turcat %}
                  <span class="tag-item">{{ item.entity.name.value }}</span>
                  {% endfor %}
                </div>
              </li>
   {% endif %}
              <li>
                <strong>Evento Gratuito:</strong>
                {{ node.field_evento_gratuito.value ? 'Sí' : 'No' }}
              </li>
              <li>
                <strong>Hora de Inicio del evento </strong>
                {{node.field_hora_de_inicio_del_evento.0.value}}
              </li>

              <li>
                <strong>Subcategoría relacionada </strong>
                <div class="tag-container">
                  {% for item in node.field_tursubcat %}
                  <span class="tag-item">{{ item.entity.name.value }}</span>
                  {% endfor %}
                </div>
              </li>
              {% if node.field_turpara|length > 0 %}
              <li>
                <strong>Recomendado para:</strong>
                <div class="tag-container">
                  {% for item in node.field_turpara %}
                  <span class="tag-item">{{ item.entity.name.value }}</span>
                  {% endfor %}
                </div>
              </li>
              {% endif %}

              {% if node.field_turzone|length > 0 %}
              <li>
                <strong>Zona:</strong>
                <div class="tag-container">
                  {% for item in node.field_turzone %}
                  <span class="tag-item">{{ item.entity.name.value }}</span>
                  {% endfor %}
                </div>
              </li>
              {% endif %}

              {% if node.field_turdistr|length > 0 %}
              <li>
                <strong>Localidad:</strong>
                <div class="tag-container">
                  {% for item in node.field_turdistr %}
                  <span class="tag-item">{{ item.entity.name.value }}</span>
                  {% endfor %}
                </div>
              </li>
              {% endif %}
              {% if node.field_correo.0.value is not empty %}
              <li class="flexList contact-info">
                <img src="/{{ directory }}/images/visitbogota/email.png" alt="email">
                <a href="mailto:{{node.field_correo.0.value}}">{{node.field_correo.0.value}}</a>
              </li>
              {% endif %}
              {% if node.field_telefono.0.value is not empty %}
              <li class="flexList contact-info">
                <img src="/{{ directory }}/images/visitbogota/tel.png" alt="tel">
                <a href="tel:{{node.field_telefono.0.value}}">{{node.field_telefono.0.value}}</a>
              </li>
              {% endif %}
            </ul>
          </div>
          <div class="contact">
          </div>
          <div class="buttons">
            {% if node.field_weblink.0.url is not empty %}
            <a href="{{node.field_weblink.0.url}}" class="btn" target="_blank" aria-label="Más información">Más
              información</a>
            {% endif %}
            {% if node.field_link_a_boleteria.0.url is not empty %}
            <a href="{{node.field_link_a_boleteria.0.url}}" class="btn" target="_blank"
              aria-label="Boletería">Boletería</a>
            {% endif %}
          </div>
          <div class="map">
            <iframe id="mapNode" width="600" height="450" style="border:0" loading="lazy" allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.google.com/maps?q={{node.field_latlong.0.value}},{{node.field_latlong.1.value}}&z=15&output=embed">
            </iframe>
          </div>
        </div>
      </div>

    </div>
    {% set has_items = false %}
    {% for item in eventosVisit %}
    {% if item.id != node.nid.value %}
    {% set has_items = true %}
    {% endif %}
    {% endfor %}
    {% if has_items %}
    <div class="lugares" style="padding: 20px;">
      <h4>
        Otros eventos de {{ content.field_turcat.0['#title'] }} que te pueden interesar
      </h4>

      <ul>
        {% set count = 0 %}

        {% for item in eventosVisit|shuffle %}
        {% if item.id != node.nid.value and count < 4 %} <li>
          <a href="{{ item.url }}">
            <img src="{{ item.image }}" alt="{{ item.title }}">
            <div class="info" style="    
    background-color: #fff;
flex-direction: column;
    border-radius: 0 0 10px 10px;">
              <div class="title" style="padding: 0;
    background-color: transparent;
    font-weight: 800;
    font-size: 16px;
    border-radius: 0 0">{{ item.title }}</div>
              {# Pre-calculamos fechas para evitar repetición #}
              {% set fecha_inicio_raw = item.field_fecha_de_inicio|date("Y-m-d") %}
              {% set fecha_fin_raw = item.field_fecha_de_finalizacion|date("Y-m-d") %}

              {# Formateo de meses traducidos para la visualización #}
              {% set mes_ini = item.field_fecha_de_inicio|date("M") %}
              {% set mes_fin = item.field_fecha_de_finalizacion|date("M") %}

              {# Solo traducimos si el sitio está en español #}
              {% set display_inicio = (meses[mes_ini] is defined) ? meses[mes_ini] ~
              item.field_fecha_de_inicio|date(" d") : item.field_fecha_de_inicio|date("M d") %}

              {% set display_fin = (meses[mes_fin] is defined) ? meses[mes_fin] ~
              item.field_fecha_de_finalizacion|date(" d") : item.field_fecha_de_finalizacion|date("M d") %}
              <div class="date" style="color:#000;display: flex;align-items: center;gap:10px;
    ">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M5.33333 1.33325V3.99992M10.6667 1.33325V3.99992M14 9.33325V3.99992C14 3.6463 13.8595 3.30716 13.6095 3.05711C13.3594 2.80706 13.0203 2.66659 12.6667 2.66659H3.33333C2.97971 2.66659 2.64057 2.80706 2.39052 3.05711C2.14048 3.30716 2 3.6463 2 3.99992V13.3333C2 13.6869 2.14048 14.026 2.39052 14.2761C2.64057 14.5261 2.97971 14.6666 3.33333 14.6666H8.66667M2 6.66658H14M10.6667 13.3333L12 14.6666L14.6667 11.9999"
                    stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {{ display_inicio }}{% if fecha_inicio_raw != fecha_fin_raw %} - {{ display_fin
                }}{% endif %}
              </div>

              <div class="place" style="color:#000;display: flex;align-items: center;gap:10px;
    "><svg width="13" height="16" viewBox="0 0 13 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M11.6667 6.33333C11.6667 9.662 7.974 13.1287 6.734 14.1993C6.61848 14.2862 6.47787 14.3332 6.33333 14.3332C6.1888 14.3332 6.04818 14.2862 5.93267 14.1993C4.69267 13.1287 1 9.662 1 6.33333C1 4.91885 1.5619 3.56229 2.5621 2.5621C3.56229 1.5619 4.91885 1 6.33333 1C7.74782 1 9.10438 1.5619 10.1046 2.5621C11.1048 3.56229 11.6667 4.91885 11.6667 6.33333Z"
                    stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  <path
                    d="M6.33333 8.33333C7.4379 8.33333 8.33333 7.4379 8.33333 6.33333C8.33333 5.22876 7.4379 4.33333 6.33333 4.33333C5.22876 4.33333 4.33333 5.22876 4.33333 6.33333C4.33333 7.4379 5.22876 8.33333 6.33333 8.33333Z"
                    stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>

                {{item['field_lugar_del_evento']}}
              </div>
            </div>
          </a>
          </li>

          {% set count = count + 1 %}
          {% endif %}
          {% endfor %}
      </ul>
    </div>
    {% endif %}
  </main>
</div>
{% endif %}